#!/usr/bin/env python3
"""Thin entrypoint: core CLI (DB/modules) + ATAF test commands."""

import os
import sys

import click
from colorama import init as colorama_init

from cli_base import EappointmentCli
from cli_test import TestCli

colorama_init()


@click.group()
def cli():
  """zmslocaldev helper: modules, database, clean, tests."""
  pass


def main():
  repo_dir = os.path.dirname(os.path.abspath(sys.argv[0]))
  EappointmentCli(repo_dir).register(cli)
  TestCli(repo_dir).register_tests(cli)
  cli()


if __name__ == "__main__":
  main()
