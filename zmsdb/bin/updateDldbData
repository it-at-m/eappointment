#!/usr/bin/env php
<?php
require_once(__DIR__."/script_bootstrap.php");

if (!\BO\Zmsdb\Source\Zmsdldb::$importPath) {
            \App::$log->error('MISSING dldb data directory. Does a config.php exist?');
}

if (isset($argv[1]) && $argv[1] == '--commit') {
    $importer = new \BO\Zmsdb\Source\Zmsdldb();
            \App::$log->info('Starting services import', [
            'arguments' => is_array($argv) ? $argv : [$argv],
        ]);
    $importer->startImport(preg_grep('#--?v(erbose)?#', $argv));
            \App::$log->info('Finished services import');
} else {
    $dbname = \BO\Zmsdb\Connection\Select::$writeSourceName;
            \App::$log->notice('updateDldbData usage', [
            'usage' => "Usage: {$argv[0]} --commit [--verbose]",
            'database' => $dbname,
        ]);
}
