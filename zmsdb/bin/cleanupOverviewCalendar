#!/usr/bin/env php
<?php
require_once __DIR__ . '/script_bootstrap.php';

$now = date('Y-m-d H:i:s');

    \App::$log->info('cleanupOverviewCalendar started', ['time' => $now]);

if (!in_array('--commit', $argv, true)) {
            \App::$log->notice('cleanupOverviewCalendar dry run (no --commit), exiting');
    exit(0);
}

$svc = new \BO\Zmsdb\OverviewCalendar();
$svc->deleteOlderThan(new DateTimeImmutable('today'));

$end = date('Y-m-d H:i:s');
    \App::$log->info('cleanupOverviewCalendar finished', ['time' => $end]);
