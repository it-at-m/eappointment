#!/usr/bin/env php
<?php
require_once(__DIR__."/script_bootstrap.php");

$verbose = (preg_grep('#^--?v(erbose)?$#', $argv)) ? true : false;
$commit = preg_grep('#^--commit$#', $argv);

if (!$commit) {
            \App::$log->notice('Use with --commit to delete entries.');
    exit(0);
}

$job = new \BO\Zmsdb\Helper\CleanProcessArchivedToday($verbose);
$job->startProcessing($commit);
