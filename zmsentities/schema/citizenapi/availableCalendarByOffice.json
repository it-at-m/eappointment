{
  "title": "AvailableCalendarByOffice",
  "type": ["array", "object", "null"],
  "properties": {
    "startDate": {
      "type": "string",
      "description": "Start date of the requested range in YYYY-MM-DD format"
    },
    "endDate": {
      "type": "string",
      "description": "End date of the requested range in YYYY-MM-DD format"
    },
    "availableDays": {
      "type": ["array", "null"],
      "description": "Bookable days with appointment slots grouped by office",
      "items": {
        "type": ["array", "object", "null"],
        "properties": {
          "time": {
            "type": "string",
            "description": "Day in YYYY-MM-DD format"
          },
          "providerIDs": {
            "type": "string",
            "description": "Comma-separated office IDs"
          },
          "offices": {
            "type": ["array", "null"],
            "items": {
              "type": ["array", "object", "null"],
              "properties": {
                "officeId": {
                  "type": "string",
                  "description": "Office ID"
                },
                "appointments": {
                  "type": ["array", "null"],
                  "items": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["startDate", "endDate", "availableDays"],
  "description": "Schema defining available days and appointment slots for offices and services"
}
