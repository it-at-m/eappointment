{
    "type": "object",
    "description": "A role bundles a set of atomic permissions that can be assigned to useraccounts.",
    "example": {
        "id": 8,
        "name": "system_admin",
        "description": "Technische Administration",
        "permissions": [
            "superuser"
        ],
        "assignedUserCount": 0
    },
    "required": [
        "name",
        "description"
    ],
    "properties": {
        "id": {
            "type": "integer",
            "description": "Numeric identifier of the role."
        },
        "name": {
            "type": "string",
            "description": "Unique technical name stored in the database (e.g. agent_queue, appointment_admin).",
            "pattern": "^[a-z][a-z0-9_]{0,99}$"
        },
        "description": {
            "type": "string",
            "minLength": 1,
            "description": "Display label for administrators."
        },
        "assignedUserCount": {
            "type": "integer",
            "minimum": 0,
            "readOnly": true,
            "description": "Number of user accounts that have this role assigned."
        },
        "permissions": {
            "type": "array",
            "description": "List of permission names that are granted by this role.",
            "items": {
                "type": "string"
            }
        }
    }
}
