#!/usr/bin/env php
<?php
ini_set('memory_limit', '1024M');
require_once(__DIR__."/script_bootstrap.php");

$dates = preg_grep('#^\d\d\d\d-\d\d?-\d\d?#', $argv);
$now = new \DateTimeImmutable();
if (count($dates)) {
    $now = new \DateTimeImmutable(array_shift($dates));
} elseif (class_exists('\App') && isset(\App::$now)) {
    $now = \App::$now;
}
if (preg_grep('#^--repair$#', $argv)) {
    // repair flag consumed by CalculateSlots via argv
}
if (preg_grep('#^--commit$#', $argv)) {
    \App::$log->info('Start slot calculation', ['time' => $now->format('c')]);
    $calculator = new \BO\Zmsbackend\Helper\CalculateSlots(preg_grep('#^--?v(erbose)?$#', $argv));
    try {
        $stepStart = microtime(true);
        $delete = preg_grep('#^--delete$#', $argv);
        $calculator->writeCalculations($now, $delete);
        \App::$log->info('Slot calculation finished', [
            'duration_seconds' => round(microtime(true) - $stepStart, 2),
        ]);
    } catch (\BO\Zmsbackend\Exception\Pdo\LockTimeout $exception) {
        $calculator->log("Unexpected end due to lock timeout, showing tracelog:");
        $calculator->dumpLogs();
        \App::$log->error('Slot calculation lock timeout', [
            'trace' => $exception->getTraceAsString(),
        ]);
    } catch (\Exception $exception) {
        $calculator->dumpLogs();
        throw $exception;
    }
} else {
    \App::$log->notice('calculateSlots usage', [
        'usage' => "Usage: {$argv[0]} --commit [--verbose] [--delete] [--repair] [2018-04-01]",
        'database' => \BO\Zmsbackend\Connection\Select::$writeSourceName,
        'username' => \BO\Zmsbackend\Connection\Select::$username,
        'calculationTime' => $now->format('c'),
    ]);
}
