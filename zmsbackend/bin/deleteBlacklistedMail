#!/usr/bin/env php
<?php
require_once(__DIR__."/script_bootstrap.php");

$commit = preg_grep('#^--commit$#', $argv);
$verbose = preg_grep('#^--verbose$#', $argv);

$query = new \BO\Zmsbackend\Process\Service\Process();
$mailAddressList = explode(',', (new \BO\Zmsbackend\Config\Service\Config)->readProperty('notifications__blacklistedAddressList'));

foreach ($mailAddressList as $mailAddress) {
    $mailAddress = trim($mailAddress);
    if ($mailAddress) {
        if ($verbose) {
            \App::$log->info('Delete blacklisted mail address', [
                'mailAddressHash' => $query->hashStringValue($mailAddress, 'sha256'),
            ]);
        }
        $results = [];
        $maxRuns = $verbose ? 1 : 20;
        do {
            foreach ($results as $process) {
                if ($verbose) {
                    \App::$log->info('Change process mail', ['processId' => $process->id]);
                }
                if ($commit) {
                    $process->getFirstClient()->email = '';
                    $query->updateEntity($process, new \DateTimeImmutable());
                }
            }
            $results = $query->readProcessListByMailAddress($mailAddress, null, 0, 500);
        } while ($results->count() && $maxRuns--);
    }
}

if (!$commit) {
    \App::$log->notice('deleteBlacklistedMail requires --commit (and optionally --verbose)');
}
