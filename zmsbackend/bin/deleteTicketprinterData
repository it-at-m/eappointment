#!/usr/bin/env php
<?php
require_once(__DIR__."/script_bootstrap.php");

$verbose = preg_grep('#^--?v(erbose)?$#', $argv);
$commit = preg_grep('#^--commit$#', $argv);

$job = new \BO\Zmsbackend\Helper\TicketprinterDeleteByCron($verbose);

if (!$commit) {
    \App::$log->notice('Use with --commit to delete entries.');
}
if ($commit || $verbose) {
    $job->startProcessing($commit);
} else {
    \App::$log->notice('deleteTicketprinterData requires --commit or --verbose');
}
