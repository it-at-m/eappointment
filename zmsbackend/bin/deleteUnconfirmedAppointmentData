#!/usr/bin/env php
<?php
require_once(__DIR__."/script_bootstrap.php");

$verbose = (preg_grep('#^--?v(erbose)?$#', $argv)) ? true : false;
$commit = preg_grep('#^--commit$#', $argv);

if ($verbose) {
    \App::$log->debug('deleteUnconfirmedAppointmentData started', ['cwd' => getcwd()]);
}

if (class_exists('\App') && isset(\App::$now)) {
    $now = \App::$now;
} else {
    $now = new \DateTimeImmutable('now');
}
$job = new \BO\Zmsbackend\Helper\UnconfirmedAppointmentDeleteByCron($now, $verbose);
$job->startProcessing($commit);

if (!$commit) {
    \App::$log->notice('Use with --commit to delete entries.');
}
