VITE_NODE_ENV=production
VITE_VUE_APP_API_URL=/buergeransicht/api/citizen
# For zmsautomation / ATAF containerized runs (hostname: citizenview)
VITE_VUE_APP_API_URL_CONTAINER="http://refarch-gateway:8080/buergeransicht/api/citizen"
VITE_VUE_APP_SERVICE_BASE_URL="https://stadt.muenchen.de/service/info/"

# Built demo host pages only; real embedders supply their own dbs-login attributes.
VITE_USE_LOCAL_CITIZEN_LOGIN=false
VITE_DBS_LOGIN_LOADER_URL=https://dbs-login-webcomponent-integration.muenchen.de/loader.js
VITE_KC_URL=https://ssodev.muenchen.de/auth
VITE_KC_REALM=A61
VITE_KC_CLIENT_ID=dbs-fragments

