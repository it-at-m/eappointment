{% use "block/timer/time.twig" %}
{% block pageheader %}

<div id="main-header" class="noprint">
	<span>
        {% if languages is not empty %}
        <div class="languages">
            {% for lang in languages %}
                <div class="lang" data-lang-id="{{ loop.index0 }}" data-lang="{{ lang }}">
                    <a href="{{ app.request.uri ~ '?' ~ urlQueryString|replace({('lang=' ~ currentLang): 'lang=' ~ lang}) }}">
                        <img src="_img/flags/{{ lang }}.svg" alt="" />
                    </a>
                </div>
            {% endfor %}
        </div>
        {% endif %}

        <div class="adressangabe">
            <div class="adressangabe_name">{{ department.name }}</div>
        </div>

    </span>
    {% block timer %}
        {{ parent() }}
    {% endblock %}
</div>

{% endblock %}
