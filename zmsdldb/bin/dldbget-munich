#!/usr/bin/env php
<?php

error_reporting(E_ALL);
ini_set('display_errors', 1);

// Try to find autoload.php in various locations
if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    require __DIR__ . '/../vendor/autoload.php';
} elseif (file_exists(__DIR__ . '/../../../../vendor/autoload.php')) {
    require __DIR__ . '/../../../../vendor/autoload.php';
} elseif (file_exists('vendor/autoload.php')) {
    require 'vendor/autoload.php';
} else {
    // Fallback for production where symlink in vendor/bin points here
    $path = realpath(__DIR__ . '/../../../../vendor/autoload.php');
    if ($path && file_exists($path)) {
        require $path;
    } else {
        die("Could not find autoload.php\n");
    }
}

require_once(__DIR__ . "/script_bootstrap.php");

use Garden\Cli\Cli;
use Httpful\Request;
use BO\Zmsdldb\Transformers\Munich;

require_once(__DIR__ . "/dldb-helpers.php");

// Initialize Httpful
Request::ini(Request::init());

$cli = new Cli();
$cli->description("Downloads Munich SADB export and transforms it to Berlin-compatible format")
    ->opt('output:o', 'Path to save files', true)
    ->opt('base:b', 'Munich SADB index URL', true);
$args = $cli->parse($argv, true);

$destinationPath = $args->getOpt('output');
$indexUrl = $args->getOpt('base');

$helpers = new DldbHelpers($destinationPath, $cli);

// Ensure destination directory exists (aligned with default script)
if (!is_dir($destinationPath) && !mkdir($destinationPath, 0777, true) && !is_dir($destinationPath)) {
    print($cli->red("Failed to create the destination directory at $destinationPath\n\n"));
    exit(1);
}

// Check for rollback
$rollbackDay = $helpers->getRollbackDay();
if ($rollbackDay !== "none") {
    $helpers->performRollback($rollbackDay);
    exit(0);
}

print("No rollback is requested, fetching current Munich SADB export...\n\n");

$transformer = new Munich();
try {
    $data = $transformer->fetchLatestExport($indexUrl);
} catch (\Exception $e) {
    echo "Error: Failed to fetch Munich SADB export: " . $e->getMessage() . "\n\n";
    exit(1);
}

// Same as dldb-mapper mapImport mergeExports(prod.json): Passkalender 10502 + relations for E2E/prod parity
$data = $transformer->applySadbOverwrite($data);
print("Applied bundled munich_sadb_overwrite.json (dldb-mapper parity).\n\n");

// Helper: write JSON to temp file (aligned with dldbget pattern)
function writeJsonTempFile($data)
{
    $json = json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
    if ($json === false) {
        echo "Error: JSON encoding failed: " . json_last_error_msg() . "\n\n";
        exit(1);
    }

    $tempFile = tempnam(sys_get_temp_dir(), 'dldbget_');
    if ($tempFile === false) {
        echo "Error: Failed to create temporary file\n\n";
        exit(1);
    }

    if (file_put_contents($tempFile, $json) === false) {
        echo "Error: Failed to write temporary file\n\n";
        @unlink($tempFile);
        exit(1);
    }

    return $tempFile;
}

$downloadedFiles = [];

// Transform services
print("Transforming services...\n\n");
$servicesData = $transformer->transformServices($data);
$downloadedFiles['services_de.json'] = writeJsonTempFile($servicesData);

// Transform locations
print("Transforming locations...\n\n");
$locationsData = $transformer->transformLocations($data, $servicesData);
$downloadedFiles['locations_de.json'] = writeJsonTempFile($locationsData);

// Empty placeholder data (Munich has no EN / topics / authority yet)
$emptyData = [
    'data' => [],
    'meta' => [
        'generated' => date('Y-m-d\TH:i:s'),
        'datacount' => 0,
    ],
];

$downloadedFiles['services_en.json'] = writeJsonTempFile($emptyData);
$downloadedFiles['locations_en.json'] = writeJsonTempFile($emptyData);
$downloadedFiles['topic_de.json'] = writeJsonTempFile($emptyData);
$downloadedFiles['authority_de.json'] = writeJsonTempFile($emptyData);
$downloadedFiles['settings.json'] = writeJsonTempFile($emptyData);

try {
    // Check if backup is needed and perform backup
    $helpers->checkAndCreateBackup($downloadedFiles);
} finally {
    // Copy downloaded temp files to the destination folder and remove the temp files
    $helpers->copyDownloadedTempFilesToDestinationAndUnlink($downloadedFiles);
}

// Cleanup old backups
$helpers->cleanupOldBackups();

print("Munich transformation completed!\n\n");
