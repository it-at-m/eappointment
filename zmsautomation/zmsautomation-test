#!/usr/bin/env bash
  set -euo pipefail

# Capture Maven arguments (e.g., -Dcucumber.filter.tags="@smoke" to run specific tags)
MAVEN_ARGS=("$@")

info() { echo "[INFO] $*"; }
warn() { echo "[WARN] $*"; }

SECTION_BAR="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
SECTION_COLOR_RESET=$'\033[0m'
SECTION_COLOR_INDEX=0
SECTION_COLORS=()
USE_SECTION_COLORS=false
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  SECTION_COLORS=(
    $'\033[38;5;196m' # red
    $'\033[38;5;208m' # orange
    $'\033[38;5;226m' # yellow
    $'\033[38;5;46m'  # green
    $'\033[38;5;51m'  # cyan
    $'\033[38;5;21m'  # blue
    $'\033[38;5;201m' # magenta
  )
  if [[ ${#SECTION_COLORS[@]} -gt 0 ]]; then
    USE_SECTION_COLORS=true
  fi
fi

section() {
  local title="$*"
  local prefix="" suffix=""
  if [[ "$USE_SECTION_COLORS" == true ]]; then
    prefix="${SECTION_COLORS[$SECTION_COLOR_INDEX]}"
    suffix="$SECTION_COLOR_RESET"
    SECTION_COLOR_INDEX=$(((SECTION_COLOR_INDEX + 1) % ${#SECTION_COLORS[@]}))
  fi
  echo ""
  echo "${prefix}${SECTION_BAR}${suffix}"
  echo "${prefix}[SECTION] $title${suffix}"
  echo "${prefix}${SECTION_BAR}${suffix}"
  echo ""
}

# Paths and variables
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Validate required environment variables
: "${MYSQL_PORT:?MYSQL_PORT must be set}"
: "${MYSQL_DATABASE:?MYSQL_DATABASE must be set}"
: "${MYSQL_USER:?MYSQL_USER must be set}"
: "${MYSQL_PASSWORD:?MYSQL_PASSWORD must be set}"
: "${CACHE_DIR:?CACHE_DIR must be set}"

DB_NAME="${MYSQL_DATABASE}"
DB_USER="${MYSQL_USER}"
DB_PASSWORD="${MYSQL_PASSWORD}"
DB_HOST="${MYSQL_HOST:-db}"  # Defaults to 'db' (docker-compose service name)
DB_PORT="${MYSQL_PORT##*:}"  # Extract port from "tcp://host:port" or just "port"

# Mock Date/Time (ONE value for the whole run, inside opening-hours)
export ZMS_TIMEADJUST="${ZMS_TIMEADJUST:-$(TZ=Europe/Berlin date '+%Y-%m-%d %H:%M:%S')}"
info "Using mocked time for all processes and requests: $ZMS_TIMEADJUST"

# File paths
BACKUP_FILE="/tmp/zms_backup_$(date +%s).sql.gz"
BASE_SQL_FILE="$PROJECT_ROOT/.resources/zms.sql"
FLYWAY_DIR="$PROJECT_ROOT/zmsautomation/src/main/resources/db/migration"

# API endpoints (for health checks from inside container)
BASE_URI="${BASE_URI:-http://localhost/terminvereinbarung/api/2}"
CITIZEN_API_BASE_URI="${CITIZEN_API_BASE_URI:-http://localhost/terminvereinbarung/api/citizen}"
CITIZENVIEW_PORT="${CITIZENVIEW_PORT:-8082}"
# Inside the devcontainer network, citizenview is reachable via its service name.
CITIZENVIEW_BASE_URI="${CITIZENVIEW_BASE_URI:-http://citizenview:${CITIZENVIEW_PORT}}"
# Make the base URI also available for ATAF's Environment as ZMS-Citizen-View.
export CITIZEN_VIEW_BASE_URI="${CITIZENVIEW_BASE_URI}"

# Keycloak config files
KEYCLOAK_STATISTIC_JSON="$PROJECT_ROOT/zmsstatistic/keycloak.json"
KEYCLOAK_ADMIN_JSON="$PROJECT_ROOT/zmsadmin/keycloak.json"

# Cleanup function to clear zmsapi/data folder (preserve .gitignore)
cleanup_data_folder() {
  if [ -d "$PROJECT_ROOT/zmsapi/data" ]; then
    find "$PROJECT_ROOT/zmsapi/data" -mindepth 1 -not -name ".gitignore" -delete || warn "Failed to clean data folder"
    [ -f "$PROJECT_ROOT/zmsapi/data/.gitignore" ] || printf "*\n!.gitignore\n" > "$PROJECT_ROOT/zmsapi/data/.gitignore"
  fi
}

# Clear caches
clear_caches() {
  if [[ -n "${CACHE_DIR:-}" && -d "$CACHE_DIR" ]]; then
    info "Clearing caches in $CACHE_DIR..."
    find "$CACHE_DIR" -mindepth 1 -delete || warn "Failed to clear caches"
  else
    warn "CACHE_DIR not set or does not exist"
  fi
}

# Database helper function
exec_sql() {
  mysql --ssl=0 -h "$DB_HOST" -P "$DB_PORT" -u "$DB_USER" --password="$DB_PASSWORD" "$DB_NAME" "$@"
}

exec_sql_root() {
  mysql --ssl=0 -h "$DB_HOST" -P "$DB_PORT" -u root --password="${MYSQL_ROOT_PASSWORD:-root}" "$@"
}

# Backup database
backup_db() {
  info "Backing up database to $BACKUP_FILE..."
  mysqldump --ssl=0 -h "$DB_HOST" -P "$DB_PORT" -u "$DB_USER" --password="$DB_PASSWORD" "$DB_NAME" | gzip > "$BACKUP_FILE"
  info "Backup completed."
}

# Restore database
restore_db() {
  if [[ -f "$BACKUP_FILE" ]]; then
    info "Restoring database from $BACKUP_FILE..."
    gunzip < "$BACKUP_FILE" | exec_sql
    info "Database restored."
  else
    warn "No backup file found to restore."
  fi
}

# --- Freeze Firefox time only (no global LD_PRELOAD) ------------------------
write_firefox_freeze_wrapper() {
  cat >/usr/local/bin/firefox-frozen <<'EOF'
#!/bin/bash
FAKE_NOW="${FAKETIME_TARGET:-${ZMS_TIMEADJUST:-2026-03-02 10:00:00}}"
SO="/usr/lib/x86_64-linux-gnu/faketime/libfaketime.so.1"
[ -f "$SO" ] || SO="/usr/lib/faketime/libfaketime.so.1"
# Only Firefox sees faketime (not geckodriver)
export FAKETIME="@${FAKE_NOW}"
export FAKETIME_NO_CACHE=1
export FAKETIME_DONT_RESET=1
export FAKETIME_DONT_FAKE_MONOTONIC=1     # important for Gecko
export MOZ_DISABLE_CONTENT_SANDBOX=1      # avoid sandbox conflict
export LD_PRELOAD="$SO${LD_PRELOAD+:$LD_PRELOAD}"
exec /usr/bin/firefox-esr "$@"
EOF
  chmod +x /usr/local/bin/firefox-frozen
}

switch_firefox_to_frozen() {
  # Remember original target for restore
  export __PREV_FIREFOX_BIN_TARGET="$(readlink -f /usr/bin/firefox || echo /usr/bin/firefox-esr)"
  ln -sf /usr/local/bin/firefox-frozen /usr/bin/firefox
  info "Firefox binary switched to wrapper (/usr/local/bin/firefox-frozen)"
}

restore_firefox_binary() {
  if [ -n "${__PREV_FIREFOX_BIN_TARGET-}" ] && [ -e "$__PREV_FIREFOX_BIN_TARGET" ]; then
    ln -sf "$__PREV_FIREFOX_BIN_TARGET" /usr/bin/firefox
    info "Firefox binary restored to $__PREV_FIREFOX_BIN_TARGET"
  fi
}

cleanup_on_exit() {
  info "Running cleanup..."
  
  # 1. Restore time first (most critical for developer environment)
  restore_firefox_binary  || true
  
  # 2. Restore database
  restore_db
  
  # 3. Restore Keycloak configs
  restore_keycloak
  
  # 4. Clear Flyway test migrations
  if [[ -n "${BACKUP_FILE:-}" ]]; then
    info "Clearing test data migrations from flyway_schema_history..."
    exec_sql -e "DELETE FROM flyway_schema_history WHERE version > 1;" 2>/dev/null || true
  fi
  
  # 5. Clear caches
  clear_caches
  
  # 6. Clean data folder
  cleanup_data_folder
  
  info "Cleanup completed."
}


backup_and_rewrite_keycloak() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cp "$file" "$file.bak"
    sed -i 's/localhost:8091/localhost:443/g' "$file"
    info "Keycloak config rewritten (8091→443): $file"
  else
    warn "Keycloak config not found: $file"
  fi
}

restore_keycloak() {
  for f in "$KEYCLOAK_STATISTIC_JSON" "$KEYCLOAK_ADMIN_JSON"; do
    if [[ -f "${f}.bak" ]]; then
      mv "${f}.bak" "$f"
      info "Keycloak config restored: $f"
    fi
  done
}

# Drop all tables
drop_all_tables() {
  info "Dropping all existing tables..."
  local drop_sql="SET FOREIGN_KEY_CHECKS = 0;
SET @tables = (SELECT GROUP_CONCAT(CONCAT('\`', table_name, '\`')) FROM information_schema.tables WHERE table_schema = '$DB_NAME' AND table_type = 'BASE TABLE');
SET @sql = IF(@tables IS NULL OR @tables = '', 'DO 0', CONCAT('DROP TABLE IF EXISTS ', @tables));
PREPARE stmt FROM @sql;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
SET FOREIGN_KEY_CHECKS = 1;"
  echo "$drop_sql" | exec_sql
  info "Tables dropped."
}

run_hourly_with_retries() {
  # Run hourly cronjob with up to 5 retries (6 attempts total)
  # Waits between attempts: 1, 2, 3, 5, 10 seconds
  local cmd=("$PROJECT_ROOT/zmsapi/cron/cronjob.hourly" --city=munich)
  local delays=(0 1 2 3 5 10) # initial attempt has no delay
  local max_attempts=${#delays[@]}
  local attempt delay

  for i in "${!delays[@]}"; do
    attempt=$((i + 1))
    delay="${delays[$i]}"

    if (( delay > 0 )); then
      info "Waiting ${delay}s before hourly cronjob attempt ${attempt}/${max_attempts}..."
      sleep "$delay"
    fi

    info "Running hourly cronjob (attempt ${attempt}/${max_attempts})..."
    if "${cmd[@]}"; then
      info "Hourly cronjob succeeded on attempt ${attempt}/${max_attempts}."
      return 0
    fi

    if (( attempt < max_attempts )); then
      warn "Hourly cronjob failed on attempt ${attempt}/${max_attempts}; will retry."
    fi
  done

  warn "Hourly cronjob failed after ${max_attempts} attempts; continuing."
  return 1
}

# Ensure cleanup on exit
trap 'cleanup_on_exit' EXIT INT TERM
trap 'warn "Failure detected, running cleanup..."; 
cleanup_on_exit; exit 1' ERR

