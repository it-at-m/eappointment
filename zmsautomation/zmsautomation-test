# 9. Health Checks (5 min total; 15s per try; bypass proxy for localhost; keep BASE_URI / CITIZEN_API_BASE_URI)
#
# citizenapi / citizenapi-available-days use CITIZEN_API_BASE_URI → http://localhost/.../api/citizen/...
# That hits zms-web (PHP) directly — refarch-gateway is NOT on that path, so gateway logs stay empty.
# Browser + Vite use http://refarch-gateway:8080/buergeransicht/api/citizen/... — we ping that too so
# gateway sees traffic and DEBUG logs prove the route. Skip with SKIP_REFARCH_GATEWAY_HEALTH=1 if no gateway.
section "9. Health Checks"
export NO_PROXY="${NO_PROXY:-localhost,127.0.0.1,::1,refarch-gateway,citizenview}"
export no_proxy="${NO_PROXY}"

join_url(){ local b="${1%/}"; local p="${2#/}"; printf '%s/%s\n' "$b" "$p"; }

HEALTH_MAX_WAIT="${HEALTH_MAX_WAIT:-300}"          # total seconds
HEALTH_INTERVAL="${HEALTH_INTERVAL:-5}"            # seconds between tries
HEALTH_PERTRY_TIMEOUT="${HEALTH_PERTRY_TIMEOUT:-15}"

ZMS_API_HEALTH_URL="$(join_url "${BASE_URI}" "status/")"
: "${CITIZEN_API_BASE_URI:?CITIZEN_API_BASE_URI must be set}"
CITIZEN_API_HEALTH_URL="$(join_url "${CITIZEN_API_BASE_URI}" "offices-and-services/")"
ZMSCITIZENVIEW_HEALTH_URL="${CITIZENVIEW_BASE_URI}"
REFARCH_GATEWAY_OFFICES_URL="${REFARCH_GATEWAY_OFFICES_URL:-http://refarch-gateway:8080/buergeransicht/api/citizen/offices-and-services/}"

# derive a date range similar to the Java steps (today .. today+6 months)
AVAIL_DAYS_START_DATE="$(TZ=Europe/Berlin date -d "${ZMS_TIMEADJUST%% *}" +%F 2>/dev/null || date +%F)"
AVAIL_DAYS_END_DATE="$(TZ=Europe/Berlin date -d "${AVAIL_DAYS_START_DATE} +6 months" +%F 2>/dev/null || date -d '+6 months' +%F 2>/dev/null || date +%F)"

# health check for available days (zmskvr-1124 Ruppertstraße booking scenarios)
# Personalausweis at Bürgerbüro Ruppertstraße (10502) – lands at 10502
CITIZEN_API_AVAIL_DAYS_URL="$(join_url "${CITIZEN_API_BASE_URI}" "available-days-by-office/")?officeId=10502&serviceId=1063441&startDate=${AVAIL_DAYS_START_DATE}&endDate=${AVAIL_DAYS_END_DATE}&serviceCount=1"

# one-shot warm-up (ignore exit code)
curl -sS -o /dev/null --max-time 30 "$CITIZEN_API_HEALTH_URL" || true

wait_http() { # name url
  local n="$1" u="$2" tries=$(( (HEALTH_MAX_WAIT + HEALTH_INTERVAL - 1)/HEALTH_INTERVAL ))
  info "Pinging ${n}: ${u}"
  for ((i=1;i<=tries;i++)); do
    code="$(curl -sS -o /dev/null -w "%{http_code}" --max-time "${HEALTH_PERTRY_TIMEOUT}" --noproxy "localhost,127.0.0.1,::1" "$u" || echo 000)"
    [[ "$code" =~ ^2|3 ]] && { info "✓ ${n} responding (${code})"; return 0; }
    (( i<tries )) && { warn "… ${n} not ready (${code}); retry in ${HEALTH_INTERVAL}s (${i}/${tries})"; sleep "${HEALTH_INTERVAL}"; }
  done
  warn "✗ ${n} NOT responding after ${HEALTH_MAX_WAIT}s"; return 1
}

# Same as wait_http but never use HTTP proxy (refarch-gateway / Docker DNS must not go via corporate proxy)
wait_http_direct() { # name url
  local n="$1" u="$2" tries=$(( (HEALTH_MAX_WAIT + HEALTH_INTERVAL - 1)/HEALTH_INTERVAL ))
  info "Pinging ${n}: ${u}"
  for ((i=1;i<=tries;i++)); do
    code="$(curl -sS -o /dev/null -w "%{http_code}" --max-time "${HEALTH_PERTRY_TIMEOUT}" --noproxy '*' "$u" || echo 000)"
    [[ "$code" =~ ^2|3 ]] && { info "✓ ${n} responding (${code})"; return 0; }
    (( i<tries )) && { warn "… ${n} not ready (${code}); retry in ${HEALTH_INTERVAL}s (${i}/${tries})"; sleep "${HEALTH_INTERVAL}"; }
  done
  warn "✗ ${n} NOT responding after ${HEALTH_MAX_WAIT}s"; return 1
}

fail=false
wait_http "zmsapi"                     "$ZMS_API_HEALTH_URL"          || fail=true
info "citizenapi ping uses direct PHP route (not gateway): ${CITIZEN_API_HEALTH_URL}"
wait_http "citizenapi"                 "$CITIZEN_API_HEALTH_URL"      || fail=true
wait_http "citizenapi-available-days"  "$CITIZEN_API_AVAIL_DAYS_URL"  || fail=true
# zmscitizenview: must use wait_http_direct — wait_http only noproxy's localhost, so
# HTTP_PROXY still sends http://citizenview:8082 to the corporate gateway → 502.
wait_http_direct "zmscitizenview"      "$ZMSCITIZENVIEW_HEALTH_URL"   || fail=true
if [[ "${SKIP_REFARCH_GATEWAY_HEALTH:-}" == "1" ]]; then
  info "SKIP_REFARCH_GATEWAY_HEALTH=1 — not pinging refarch-gateway"
else
  wait_http_direct "refarch-gateway-offices" "$REFARCH_GATEWAY_OFFICES_URL" || fail=true
fi
$fail && { warn "One or more health checks failed"; exit 1; }

info "All health checks passed."

