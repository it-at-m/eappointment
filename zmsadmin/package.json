{
  "name": "zmsadmin",
  "version": "1.0.0",
  "description": "zms admin frontend ",
  "main": "index.js",
  "private": true,
  "author": "BerlinOnline GmbH & Co. KG",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint js/",
    "fix": "eslint --fix js/",
    "css": "parcel build scss/admin.scss --log-level verbose --detailed-report --target css",
    "js": "parcel build js/index.js --log-level verbose --detailed-report --target js",
    "reactjs": "parcel build js/reactcomponents.js --log-level verbose --detailed-report --target js",
    "csswatch": "parcel watch scss/admin.scss --log-level verbose  --target css",
    "jswatch": "parcel watch js/index.js --log-level verbose --no-hmr --target js",
    "reactwatch": "parcel watch js/reactcomponents.js --log-level verbose --no-hmr --target js",
    "watch": "npm run jswatch & npm run csswatch &",
    "build": "npm run js && npm run css && npm run reactjs"
  },
  "targets": {
    "js": {
      "publicUrl": "./",
      "distDir": "public/_js/"
    },
    "css": {
      "publicUrl": "./",
      "distDir": "public/_css/"
    }
  },
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.4",
    "buffer": "^6.0.3",
    "eslint": "^9.0.0",
    "flatted": "^3.4.2",
    "immutable": "^5.1.5",
    "minimatch": "^10.2.5",
    "picomatch": "^2.3.2",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-react": "^7.31.8",
    "events": "^3.3.0",
    "focus-trap-react": "12.0.1",
    "https-browserify": "^1.0.0",
    "jquery": "^4.0.0",
    "js-cookie": "^3.0.0",
    "js-yaml": "^4.1.1",
    "json-schema-defaults": "^0.4.0",
    "json-schema-ref-parser": "^9.0.9",
    "moment": "^2.29.1",
    "monaco-editor": "^0.55.0",
    "parcel": "^2.16.4",
    "process": "^0.11.10",
    "prop-types": "15.8.1",
    "punycode": "^2.0.0",
    "qrcode-generator": "^2.0.0",
    "querystring-es3": "^0.2.1",
    "qs": "^6.14.2",
    "react": "^18.0.2",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-to-print": "^3.0.0",
    "requirejs": "^2.3.7",
    "stream-http": "^3.2.0",
    "svgo": "^4.0.1",
    "url": "^0.11.0",
    "util": "^0.12.5"
  },
  "dependencies": {
    "bo-layout-admin-js": "https://gitlab.com/eappointment/includes/layout-admin-js/-/archive/2.24.14/layout-admin-js-2.24.14.tar.gz",
    "bo-layout-admin-scss": "https://gitlab.com/eappointment/includes/layout-admin-scss/-/archive/muc-main/layout-admin-scss-muc-main.tar.gz",
    "bo-zmsentities": "https://gitlab.com/eappointment/zmsentities/-/archive/2.24.14/zmsentities-2.24.14.tar.gz",
    "chart.js": "^4.4.2",
    "react-chartjs-2": "^5.3.1"
  },
  "// overrides.dompurify": "monaco-editor depends on dompurify@3.2.7; override to ^3.3.2 (patched) until Monaco ships a newer dompurify.",
  "overrides": {
    "dompurify": "^3.3.2"
  }
}
