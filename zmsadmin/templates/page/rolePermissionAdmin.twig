{% extends "layout/main.twig" %}

{% block content %}
    {{ parent() }}
    {% from 'element/helper/form.twig' import formgroup %}

    <div class="role-permission-view" data-includeurl="{{ includeUrl() }}">
    <div class="panel panel--heavy">
        <h1>Rollen &amp; Berechtigungen</h1>
        <p>
            Diese Übersicht zeigt die im System hinterlegten Rollen und die ihnen zugeordneten Berechtigungen.
            Superuser können hier Rollen und ihre Berechtigungen anlegen, bearbeiten und löschen.
        </p>

        <form method="post" action="{{ urlGet('rolePermissionUpdate', {}, {}) }}">
            {% if rolePermissionMatrix is empty %}
                <p>Es sind keine Rollen definiert.</p>
            {% else %}
                <table class="table table--striped table--responsive" style="table-layout: fixed; width: 100%;">
                    <thead>
                        <tr>
                            <th class="text-left" style="text-align: left; width: 10%;">Rollenname</th>
                            <th class="text-left" style="text-align: left; width: 20%">Beschreibung</th>
                            <th class="text-left" style="text-align: left; width: 45%;">Berechtigungen</th>
                            <th class="text-left" style="text-align: left; width: 10%;">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for role in rolePermissionMatrix %}
                        <tr class="roles-row" style="border-top: 1px solid #ddd;">
                            <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; vertical-align: top; width: 10%;">
                                <input type="text"
                                       id="role-name-{{ role.id }}"
                                       name="roles[{{ role.id }}][name]"
                                       value="{{ role.name }}"
                                       class="form-control"
                                       placeholder="z. B. agent_queue" />
                            </td>
                            <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; vertical-align: top; width: 20%">
                                <textarea id="role-description-{{ role.id }}"
                                          name="roles[{{ role.id }}][description]"
                                          class="form-control"
                                          rows="5"
                                          style="resize: none;"
                                          placeholder="Kurzbeschreibung der Rolle (optional)">{{ role.description }}</textarea>
                            </td>
                            <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; width: 45%;">
                                {% if permissions is not empty %}
                                    <div class="roles-permissions">
                                        {% for permission in permissions %}
                                            <label class="checkbox roles-permissions__item"
                                                   title="{{ permission.description }}">
                                                <input type="checkbox"
                                                       name="roles[{{ role.id }}][permissions][]"
                                                       value="{{ permission.id }}"
                                                       {% if permission.name in role.permissions %}checked="checked"{% endif %} />
                                                <span class="badge badge--light">
                                                    <code>{{ permission.name }}</code>
                                                </span>
                                            </label>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <em>Keine Berechtigungen definiert.</em>
                                {% endif %}
                            </td>
                            <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; width: 10%;">
                                <a href="{{ urlGet('rolePermissionDelete', {id: role.id}, {}) }}"
                                   class="button button--destructive button-delete"
                                   title="Rolle löschen"
                                   data-name="{{ role.name }}">
                                    <i class="fas fa-trash" aria-hidden="true"></i>
                                    <span class="visually-hidden">Rolle löschen</span>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}

            <h2>Neue Rolle anlegen</h2>
            <table class="table table--striped table--responsive" style="table-layout: fixed; width: 100%;">
                <thead>
                    <tr>
                        <th class="text-left" style="text-align: left; width: 10%;">Rollenname</th>
                        <th class="text-left" style="text-align: left; width: 20%">Beschreibung</th>
                        <th class="text-left" style="text-align: left; width: 55%;">Berechtigungen</th>
                        <th class="text-left" style="text-align: left; width: 0%;"></th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="roles-row" style="border-top: 1px solid #ddd;">
                        <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; vertical-align: top; width: 10%;">
                            <input type="text"
                                   id="new-role-name"
                                   name="newRole[name]"
                                   value=""
                                   class="form-control"
                                   placeholder="z. B. agent_queue" />
                        </td>
                        <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; vertical-align: top; width: 20%">
                            <textarea id="new-role-description"
                                      name="newRole[description]"
                                      class="form-control"
                                      rows="5"
                                      style="resize: none;"
                                      placeholder="Kurzbeschreibung der Rolle (optional)"></textarea>
                        </td>
                        <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; width: 55%;">
                            {% if permissions is not empty %}
                                <div class="roles-permissions">
                                    {% for permission in permissions %}
                                        <label class="checkbox roles-permissions__item"
                                               title="{{ permission.description }}">
                                            <input type="checkbox"
                                                   name="newRole[permissions][]"
                                                   value="{{ permission.id }}" />
                                            <span class="badge badge--light">
                                                <code>{{ permission.name }}</code>
                                            </span>
                                        </label>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <em>Keine Berechtigungen definiert.</em>
                            {% endif %}
                        </td>
                        <td class="text-left" style="padding-top: 0.75rem; padding-bottom: 0.75rem; width: 10%;"></td>
                    </tr>
                </tbody>
            </table>

            <div class="form-actions">
                <button type="submit" class="button button--primary">
                    Rollen &amp; Berechtigungen speichern
                </button>
            </div>
        </form>
    </div>
    </div>
{% endblock %}

