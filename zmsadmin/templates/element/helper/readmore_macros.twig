{# Lightbox heading: appointment Nr., optional family name, optional field label (omit empty segments; no generic "Text"). #}
{% macro readmore_lightbox_title(displayNumber, familyName, fieldLabel) %}
	{% set num = displayNumber is not null ? displayNumber|trim : '' %}
	{% set name = familyName|default('')|trim %}
	{% set label = fieldLabel|default('')|trim %}
	{% set segs = [] %}
	{% if num != '' %}
		{% set segs = segs|merge([num]) %}
	{% endif %}
	{% if name != '' %}
		{% set segs = segs|merge([name]) %}
	{% endif %}
	{% if label != '' %}
		{% set segs = segs|merge([label]) %}
	{% endif %}
	{{ segs|join(' | ') }}
{% endmacro %}

{# “gebucht am …” line for queue amendment column (same text in cell + lightbox meta). #}
{% macro queue_amendment_timestamp_message(item) %}
	{%- if item.queue.status == "reserved" -%}
		{% trans %}reserviert am{% endtrans %}
	{%- elseif item.queue.status == "preconfirmed" -%}
		{% trans %}Aktivierung ausstehend ab{% endtrans %}
	{%- elseif item.queue.status == "deleted" -%}
		{% trans %}wird freigegeben ab{% endtrans %}
	{%- else -%}
		{% trans %}gebucht am{% endtrans %}
	{%- endif %} {{ item.createTimestamp|date("d.m.Y, H:i") }} Uhr
{%- endmacro %}

{# Clamped preview only (no button). #}
{% macro readmore_preview_clamped(text, maxLines) %}
	{% set t = text|default('') %}
	{% if maxLines < 1 %}
		{% set maxLines = 4 %}
	{% endif %}
	{% set clampClass = maxLines <= 4 ? 'readmore-preview--lines-4' : 'readmore-preview--lines-8' %}
	<div class="readmore-preview readmore-preview--clamp {{ clampClass }}">{{ t|e|nl2br }}</div>
{% endmacro %}

{# “Mehr lesen” when content exceeds clamp; optional meta (plain text) shown under body in lightbox. #}
{% macro readmore_expand_button(text, maxLines, fieldLabel, displayNumber = null, familyName = null, metaLine = null) %}
	{% set t = text|default('') %}
	{% if maxLines < 1 %}
		{% set maxLines = 4 %}
	{% endif %}
	{% set lines = t|split("\n") %}
	{# Narrow queue cells (~300px): many wrapped “lines” need a low chars/line guess or Mehr lesen never appears. #}
	{% set charsPerWrappedLine = maxLines <= 4 ? 36 : 100 %}
	{% set needsReadmore = lines|length > maxLines or t|length > (maxLines * charsPerWrappedLine) %}
	{% set dialogTitle %}{{ _self.readmore_lightbox_title(displayNumber, familyName, fieldLabel) }}{% endset %}
	{% set meta = metaLine|default('')|trim %}
	{% if needsReadmore %}
		<button type="button" class="readmore-link js-readmore-open" data-readmore-title="{{ dialogTitle|e('html_attr') }}" data-readmore-close-label="{{ 'Schließen'|trans|e('html_attr') }}" data-readmore-json="{{ { text: t, meta: meta }|json_encode|e('html_attr') }}">{% trans %}Mehr lesen{% endtrans %}</button>
	{% endif %}
{% endmacro %}

{# Preview + inline “Mehr lesen” (Kundeninfo, custom fields, search, …). #}
{% macro readmore_content(text, maxLines, fieldLabel, displayNumber = null, familyName = null) %}
	{{ _self.readmore_preview_clamped(text, maxLines) }}
	{{ _self.readmore_expand_button(text, maxLines, fieldLabel, displayNumber, familyName, null) }}
{% endmacro %}

{# Same file as readmore_content so Twig can resolve _self (avoids getTemplateForMacro() on null across templates). #}
{% macro queue_plain_text_cell(text, maxLines, fieldLabel, displayNumber = null, familyName = null) %}
	{% set t = text|default('') %}
	<td class="limited-width" title="{{ t|replace({'\n': ' ', '\r': ''})|e('html_attr') }}">
		<div class="queue-table-text-cell">
			{{ _self.readmore_content(text, maxLines, fieldLabel, displayNumber, familyName) }}
		</div>
	</td>
{% endmacro %}
