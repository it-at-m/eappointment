{% embed "block/scaffholding/board.twig" with {'class': 'scope-appointments-by-day'} %}
    {% from 'element/helper/form.twig' import formgroup, formbutton %}
    {% set customTextfieldActivated = scope.preferences.client.customTextfieldActivated|default(0) == 1 %}
    {% set customTextfield2Activated = scope.preferences.client.customTextfield2Activated|default(0) == 1 %}
    {% set customTextfieldLabel = scope.preferences.client.customTextfieldLabel|default('')|trim %}
    {% set customTextfield2Label = scope.preferences.client.customTextfield2Label|default('')|trim %}
    {% set textColumnCount = 2 + (customTextfieldActivated ? 1 : 0) + (customTextfield2Activated ? 1 : 0) %}
    {% set textColumnWidth = (58 / textColumnCount)|number_format(2, '.', '') %}
    {% block board_title %} {{title}}{% endblock %}
    {% block board_body %}
        <script>
            let cssDef2 = '.scope-appointments-by-day .appointments-by-day-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; table-layout: fixed; }';
                cssDef2 += '.scope-appointments-by-day .appointments-by-day-table th, .scope-appointments-by-day .appointments-by-day-table td { padding: 3px 6px; text-align: left; vertical-align: top; border: 1px solid #ddd; }';
                cssDef2 += '.scope-appointments-by-day .appointments-by-day-table .col-compact { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }';
                cssDef2 += '.scope-appointments-by-day .appointments-by-day-table .col-text { white-space: normal; word-wrap: break-word; word-break: break-word; overflow-wrap: break-word; line-height: 1.25; }';
                cssDef2 += '.scope-appointments-by-day .board__body { padding: 0; margin: 0; }';
                cssDef2 += '@media print {';
                cssDef2 += ' @page { size: A4 landscape; margin: 8mm; }';
                cssDef2 += ' .navigation-primary, .one-sixths { display: none !important; }';
                cssDef2 += ' .grid { display: block !important; }';
                cssDef2 += ' .five-sixths, #page-wrapper, .board { width: 100% !important; margin: 0; padding: 0; }';
                cssDef2 += ' .scope-appointments-by-day .appointments-by-day-table { font-size: 7pt; }';
                cssDef2 += ' .scope-appointments-by-day .appointments-by-day-table th, .scope-appointments-by-day .appointments-by-day-table td { padding: 2px 4px; }';
                cssDef2 += '}';
            let style2 = document.createElement('style');
            style2.appendChild(document.createTextNode(cssDef2));
            document.head.appendChild(style2);
        </script>
        <table class="appointments-by-day-table">
            <colgroup>
                <col class="col-compact" style="width: 4%">
                <col class="col-compact" style="width: 5%">
                <col class="col-compact" style="width: 5%">
                <col class="col-compact" style="width: 9%">
                <col class="col-compact" style="width: 8%">
                <col class="col-compact" style="width: 12%">
                <col class="col-text" style="width: {{ textColumnWidth }}%">
                {% if customTextfieldActivated %}
                    <col class="col-text" style="width: {{ textColumnWidth }}%">
                {% endif %}
                {% if customTextfield2Activated %}
                    <col class="col-text" style="width: {{ textColumnWidth }}%">
                {% endif %}
            </colgroup>
            <thead>
                <tr>
                    <th class="col-compact">{{ clusterEnabled ? 'Kürzel' : 'Lfd.Nr.'}}</th>
                    <th class="col-compact">Uhrzeit</th>
                    <th class="col-compact">Nr.</th>
                    <th class="col-compact">Name</th>
                    <th class="col-compact">Telefon</th>
                    <th class="col-compact">Email</th>
                    <th class="col-text">Dienstleistung</th>
                    <th class="col-text">Anmerkungen</th>
                    {% if customTextfieldActivated %}
                        <th class="col-text">{{ customTextfieldLabel ?: 'Freitextfeld 1' }}</th>
                    {% endif %}
                    {% if customTextfield2Activated %}
                        <th class="col-text">{{ customTextfield2Label ?: 'Freitextfeld 2' }}</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for item in processList %}
                    <tr>
                        <td class="col-compact">{{ clusterEnabled ? item.scope.shortName : loop.index }}</td>
                        <td class="col-compact">{{ item.queue.arrivalTime|date('H:i') }}</td>
                        <td class="col-compact">{{ item.displayNumber }}</td>
                        <td class="col-compact">{{ item.clients.0.familyName }}</td>
                        <td class="col-compact">{{ item.clients.0.telephone }}</td>
                        <td class="col-compact">{{ item.clients.0.email }}</td>
                        <td class="col-text">{{ item.requests.0.name }}</td>
                        <td class="col-text">{{ item.amendment|default('')|e|nl2br }}</td>
                        {% if customTextfieldActivated %}
                            <td class="col-text">{{ item.customTextfield|default('')|e|nl2br }}</td>
                        {% endif %}
                        {% if customTextfield2Activated %}
                            <td class="col-text">{{ item.customTextfield2|default('')|e|nl2br }}</td>
                        {% endif %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endblock %}

{% endembed %}
