
{% from 'element/helper/form.twig' import formgroup, formbutton, custombutton, inputfield %}

{% set userAccount = userAccount|default({}) %}
{% set userAccountDepartments = userAccount.departments|default([]) %}
{% set userAccountRights = {} %}
{% set userAccountRoles = userAccount.roles|default([]) %}
    
{% set readonly = 1 %}
{% if action == "add" %}
{% set readonly = 0 %}
{% endif %}

{% if isFromOidc %}
<div class="message message--info">
    {{ ("Dieser Nutzer wurde über einen OpenID Connect Anbieter angelegt. Nutzername, E-Mail und Passwörter sind hier nicht änderbar.")|trans }}
</div>
{% endif %}

{% set providerOptions = [{"name": "Nein, lokale Anmeldung bevorzugen", "value": ""}] %}
{% for oidcProvider in oidcProviderList %}
    {% set providerOptions = providerOptions|merge([{ "value": oidcProvider, "name": "Ja, " ~ oidcProvider ~ " als Provider nutzen"}]) %}
{% endfor %}
<form action="./" method="post" class="form--base">
    <div class="fieldset">
        <div class="panel--heavy">
        {% set passwordRequired = false %}
        {% if action == "add" %}
            {% set passwordRequired = true %}
        {% endif %}

        {% if action == "add" and 0 < oidcProviderList|length %}
        <div class="fieldset">
            <div class="panel--light">
                {% set selectedOidcProvider = (providerOptions[1] is defined) ? providerOptions[1].value : "" %}
                {% if userAccount and userAccount.oidcProvider is defined %}
                    {% set selectedOidcProvider = userAccount.oidcProvider %}
                {% endif %}
                {{ formgroup(
                    {
                        "label": "Login nur über OIDC",
                        "description": "Alle wesentlichen Zugangsdaten werden ausschließlich beim OIDC Provider verwaltet",
                    },
                    [{
                        "type":"select",
                        "parameter": {
                            "label": "",
                            "accesskey":"o",
                            "name": "oidcProvider",
                            "id": "useOidcProvider",
                            "options": providerOptions,
                            "value": selectedOidcProvider
                        }
                    }]
                ) }}
            </div>
        </div>
        {% endif %}

        {{ formgroup(
            {
                "label": "Nutzername:",
                "description": metadata.id.description,
                "required": true,
                "errors": (exception and exception.data.id.messages is defined) ? exception.data.id.messages : []
            },
            [{
                "type":"input",
                "parameter": {
                    "name": "id",
                    "value": userAccount.id|default(''),
                    "maxlength": 40,
                    "readonly": (readonly and isFromOidc)
                }
            }]
        ) }}
        

        {% if not isFromOidc %}
        {% set passwordDescription = metadata.password.description + metadata.changePassword.description %}
        {{ formgroup(
            {
                "label": "Passwort:",
                "description": passwordDescription|filter((v, k) => (k == 'minLength')),
                "required": passwordRequired,
                "errors": (exception and exception.data.changePassword.messages is defined) ? exception.data.changePassword.messages : []
            },
            [{
                "type":"input",
                "parameter": {
                    "type": "password",
                    "name": "changePassword[]",
                    "maxlength": 40
                }
            }]
        ) }}

        {{ formgroup(
            {
                "label": "Passwortwiederholung:",
                "description": passwordDescription|filter((v, k) => k != 'maxLength'),
                "required": passwordRequired,
                "errors": (exception and exception.data.changePassword.messages is defined) ? exception.data.changePassword.messages : []
            },
            [{
                "type":"input",
                "parameter": {
                    "type": "password",
                    "name": "changePassword[]",
                    "maxlength": 40
                }
            }]
        ) }}
        {% endif %}

        {% if not selectedDepartment %}
            {% set departmentOptionsGroup = [] %}
            {% set departmentOneSelected = 0 %}

            {% if workstation.useraccount.permissions.superuser %}
                {% if userAccountRights.superuser|default(0) %}
                    {% set allOverSelected = 1 %}
                {% endif %}
                {% set departmentOptionsGroup = departmentOptionsGroup|merge([
                    { "value": "0", "name": "systemübergreifend", "selected": allOverSelected},
                ]) %}
            {% endif %}

            {% for ownerName, organisationList in ownerList %}
                {% for organisationName, departmentList in organisationList %}
                    {% set departmentOptions = [] %}
                    {% for department in departmentList %}
                        {% set selected = 0 %}
                        {% for selectedDepartment in userAccountDepartments %}
                            {% if department.id == selectedDepartment.id %}
                                {% if not allOverSelected %}
                                    {% set selected = 1 %}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                        {% if workstation.useraccount.permissions.superuser %}
                            {% set departmentOptions = departmentOptions|merge([
                                { "value": department.id, "name": department.name ~ " (Id: " ~ department.id ~ ")", "selected": selected }
                            ]) %}
                        {% else %}
                            {% set departmentOptions = departmentOptions|merge([
                                { "value": department.id, "name": department.name, "selected": selected }
                            ]) %}
                        {% endif %}
                    {% endfor %}
                    {% set departmentOptionsGroup = departmentOptionsGroup|merge([{ 'name' : organisationName , 'options' : departmentOptions }]) %}
                {% endfor %}
            {% endfor %}
            {{ formgroup(
                {
                    "label": "Behörde:",
                    "description": metadata.departments.description,
                    "errors": (exception and exception.data.departments.messages is defined) ? exception.data.departments.messages : []
                },
                [{
                    "type":"select",
                    "parameter": {
                        "name": "departments[][id]",
                        "multiple": 1,
                        "options": departmentOptionsGroup,
                        "size": 20
                    }
                }]
            ) }}
        {% else %}
            {{ inputfield({ "name":"departments[][id]", "type":"hidden", "value":selectedDepartment }) }}
        {% endif %}

        {# Derive selected roles from existing roles (preferred) or legacy rights for backwards compatibility #}
        {% set selectedRoles = userAccountRoles %}
        {% if selectedRoles is empty %}
            {% set selectedRoles = [] %}
            {# Legacy mapping: superuser → system_admin #}
            {% if userAccountRights.superuser|default(0) %}
                {% set selectedRoles = selectedRoles|merge(['system_admin']) %}
            {% endif %}
            {# Legacy mapping: cluster → user_admin #}
            {% if userAccountRights.cluster|default(0) %}
                {% set selectedRoles = selectedRoles|merge(['user_admin']) %}
            {% endif %}
            {# Legacy mapping: scope → appointment_admin #}
            {% if userAccountRights.scope|default(0) %}
                {% set selectedRoles = selectedRoles|merge(['appointment_admin']) %}
            {% endif %}
            {# Legacy mapping: audit → audit_viewer #}
            {% if userAccountRights.audit|default(0) %}
                {% set selectedRoles = selectedRoles|merge(['audit_viewer']) %}
            {% endif %}
            {# Default fallback: agent_queue #}
            {% if selectedRoles is empty %}
                {% set selectedRoles = ['agent_queue'] %}
            {% endif %}
        {% endif %}

        {% set currentPermissions = workstation.useraccount.permissions|default({}) %}

        {% set roleCheckboxes = [
            {
                "type":"checkbox",
                "parameter": {
                    "label": "Sachbearbeitung (Rolle: agent_queue)",
                    "name": "roles[]",
                    "value": "agent_queue",
                    "checked" : 'agent_queue' in selectedRoles,
                    "id": "role_agent_queue"
                }
            }
        ] %}

        {# Rollen für erweiterte Berechtigungen, sichtbar je nach eigenen Rechten des eingeloggten Nutzers #}
        {% if currentPermissions.statistic or currentPermissions.logs or currentPermissions.customersearch %}
            {% set roleCheckboxes = roleCheckboxes|merge([
                {
                    "type":"checkbox",
                    "parameter": {
                        "label": "Innenrevision (Rolle: audit_viewer)",
                        "name": "roles[]",
                        "value": "audit_viewer",
                        "checked" : 'audit_viewer' in selectedRoles,
                        "id": "role_audit_viewer"
                    }
                }
            ]) %}
        {% endif %}

        {% if currentPermissions.useraccount %}
            {% set roleCheckboxes = roleCheckboxes|merge([
                {
                    "type":"checkbox",
                    "parameter": {
                        "label": "Terminadministration (Rolle: appointment_admin)",
                        "name": "roles[]",
                        "value": "appointment_admin",
                        "checked" : 'appointment_admin' in selectedRoles,
                        "id": "role_appointment_admin"
                    }
                },
                {
                    "type":"checkbox",
                    "parameter": {
                        "label": "Fachliche Administration (Rolle: user_admin)",
                        "name": "roles[]",
                        "value": "user_admin",
                        "checked" : 'user_admin' in selectedRoles,
                        "id": "role_user_admin"
                    }
                }
            ]) %}
        {% endif %}

        {% if currentPermissions.superuser %}
            {% set roleCheckboxes = roleCheckboxes|merge([
                {
                    "type":"checkbox",
                    "parameter": {
                        "label": "Technische Administration (Rolle: system_admin)",
                        "name": "roles[]",
                        "value": "system_admin",
                        "checked" : 'system_admin' in selectedRoles,
                        "id": "role_system_admin"
                    }
                }
            ]) %}
        {% endif %}

            <small>*) Felder mit einem Stern müssen ausgefüllt werden.</small>
        </div>
    </div>

    {{ formgroup(
        {
            "groupTag": "fieldset",
            "legend": "Rollen",
            "controlgroupclass": "panel--heavy",
            "errors": (exception and exception.data.roles.messages is defined) ? exception.data.roles.messages : []
        },
        roleCheckboxes
    ) }}

    <div class="form-actions">
    {% set label = "Nutzer anlegen" %}
    {% if action != "add" %}
        {% set label = "Nutzerdaten ändern" %}
        {{ custombutton({ "class": "button button--destructive button-delete", "type":"delete", "target": urlGet("useraccountDelete", {"loginname": userAccount.id|default('')}, {}), "label":"Löschen", "data": {"name": userAccount.id|default('')} }) }}
    {% endif %}
    {{ formbutton({ "type":"save", "class": "button button--positive", "name": "save", "label":label, "value": "save" }) }}
    </div>
</form>