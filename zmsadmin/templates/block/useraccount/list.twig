{% embed "block/scaffholding/board.twig" with {'class': 'useraccount-list board--spaceless', 'messages': 'hide'} %}
    {% from 'element/helper/form.twig' import custombutton, inputfield %}
    {% set superuserOnlyRoles = ['system_admin', 'audit_viewer'] %}
    {% set isSuperUser = workstation.useraccount.permissions.superuser|default(false)%}
    {% block board_title %}
        {% if searchUserQuery %}
            {% trans %}Suchergebnisse für {% endtrans %} "{{ searchUserQuery }}"
        {% else %}
        {% if isSuperUser %}
            Gesamtnutzerliste
        {% else %}
            Gesamtnutzerliste für Ihren Bereich {% if department.name %}: {{ department.name }}{% endif %}
            {% endif %}
        {% endif %}
    {% endblock %}

    {% block board_body %}
        <div class="table-responsive-wrapper">
            <fieldset>
            {% if useraccountList|length == 0 %}
                <div class="message message--info" role="alert">
                    <p>Dieser Behörde ist bisher noch kein Nutzer zugeordnet.</p>
                </div>
            {% else %}
                <div class="table-action-link" style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                    {% if department.id %}
                        {{ custombutton({ "type":"new","target": urlGet("useraccountAdd", {}, {'department':department.id}), "label":'<i class="fa fa-user-plus color-positive" aria-hidden="true"></i> neue*r Nutzer*in' }) }}
                    {% else %}
                        {{ custombutton({ "type":"new","target": urlGet("useraccountAdd", {}, {}), "label":'<i class="fa fa-user-plus color-positive" aria-hidden="true"></i> neue*r Nutzer*in' }) }}
                    {% endif %}
                    </div>
                    <div>
                        {% if useraccountList|length == 1 %}({{ useraccountList|length }} Nutzer*in){% else %}({{ useraccountList|length }} Nutzer*innen){% endif %}
                    </div>
                </div>
                <table class="table--base">
                    <thead>
                        <tr>
                            <th>Loginname</th>
                            <th>Rolle</th>
                            <th>Letzter Login</th>
                            <th>Aktion</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for useraccount in useraccountList %}
                        <tr>
                            {% set userRoles = useraccount.roles|default([]) %}
                            {% set hasSuperuserOnlyRole = (userRoles|filter(roleName => roleName in superuserOnlyRoles)|length) > 0 %}
                            {% set canEditUser = isSuperUser or not hasSuperuserOnlyRole %}
                            <td>
                                {% if canEditUser %}
                                    <a href="{{ urlGet('useraccountEdit', {'loginname':useraccount.id}, {}) }}">{{ useraccount.id }}</a>
                                {% else %}
                                    {{ useraccount.id }}
                                {% endif %}
                            </td>
                            <td>
                                {% if userRoles|length > 0 %}
                                    {% for roleName in userRoles %}
                                        {{ roleMap[roleName]|default(roleName) }}{% if not loop.last %}<br>{% endif %}
                                    {% endfor %}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{% if useraccount.lastLogin %}{{ useraccount.lastLogin|date("Y-m-d") }}{% endif %}</td>
                            <td>
                                {% if canEditUser %}
                                    {{ custombutton({ "type":"edit", "class":"link" ,"target": urlGet('useraccountEdit', {'loginname':useraccount.id}, {}), "label":'<i class="fas fa-user-edit" aria-hidden="true"></i> bearbeiten' }) }}
                                {% else %}
                                    <span class="disabled" title="Keine Berechtigung">
                                        <i class="fas fa-user-edit" aria-hidden="true"></i> bearbeiten
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
            <div class="table-action-link" style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                {% if department.id %}
                    {{ custombutton({ "type":"new","target": urlGet("useraccountAdd", {}, {'department':department.id}), "label":'<i class="fa fa-user-plus color-positive" aria-hidden="true"></i> neue*r Nutzer*in' }) }}
                {% else %}
                    {{ custombutton({ "type":"new","target": urlGet("useraccountAdd", {}, {}), "label":'<i class="fa fa-user-plus color-positive" aria-hidden="true"></i> neue*r Nutzer*in' }) }}
                {% endif %}
                </div>
                <div>
                    {% if useraccountList|length == 1 %}({{ useraccountList|length }} Nutzer*in){% else %}({{ useraccountList|length }} Nutzer*innen){% endif %}
                </div>
            </div>
            </fieldset>
        </div>

    {% endblock %}

    {% block board_footer %}{% endblock %}

{% endembed %}

